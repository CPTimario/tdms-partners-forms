{
  "name": "tdm-partners-forms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/check-deeplink-key.js && next dev",
    "build": "next build",
    "start": "node ./scripts/check-deeplink-key.js && next start",
    "lint": "eslint app components lib hooks tests --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "lint:fix": "eslint app components lib hooks tests --ext .js,.jsx,.ts,.tsx --fix --max-warnings=0",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,mjs}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "filenames:check": "node scripts/check-filenames.mjs",
    "filenames:fix": "node scripts/fix-filenames.mjs",
    "test:unit": "vitest",
    "test:unit:playwright": "playwright test -c playwright.unit.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@emotion/react": "^11.12.0",
    "@emotion/styled": "^11.12.0",
    "@mui/icons-material": "^5.14.8",
    "@mui/material": "^5.14.8",
    "@mui/x-date-pickers": "^8.27.2",
    "dayjs": "^1.11.20",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.1.379",
    "qrcode": "^1.5.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-filenames": "^1.3.0",
    "eslint-plugin-import": "^2.27.5",
    "jsdom": "^29.0.1",
    "prettier": "^2.8.8",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24.14.0"
  }
}
